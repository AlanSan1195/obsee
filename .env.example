# OBSREC Environment Variables

# Frontend (opcional): base de la API de IA si no es el mismo origen.
# Vacio = mismo origen (produccion en Vercel); en dev el proxy de Vite cubre /api.
VITE_AI_API_URL=

# Backend-only AI service settings
# These belong in Vercel environment variables, never in the frontend.
AI_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
OBSREC_AI_DAILY_LIMIT=20

# Origenes frontend adicionales permitidos para invocar los POST de IA.
# Lista exacta separada por comas; no uses comodines. Produccion canonica y
# http://localhost:5173 ya estan incluidos.
OBSREC_ALLOWED_ORIGINS=

# Local development with Ollama (no external quota)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:20b
OLLAMA_TIMEOUT_MS=120000

# Busqueda web de specs de hardware. En produccion va en Vercel; para desarrollo
# local con Ollama puede vivir en .env.ollama.local (archivo no versionado).
TAVILY_API_KEY=

# Optional but recommended for production rate limits:
# https://upstash.com/
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Solo para desarrollo local sin Upstash. Vercel y NODE_ENV=production ignoran
# este opt-in y fallan cerrados si falta el almacenamiento distribuido.
OBSREC_ALLOW_MEMORY_RATE_LIMIT=false
