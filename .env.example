# OBSREC Environment Variables
# Copy this file to .env and fill in your values

# Desktop app AI backend
# In development you can point this at a local Vercel dev server.
OBSREC_AI_API_URL=http://localhost:3000

# Backend-only AI service settings
# These belong in Vercel environment variables, not in a public desktop build.
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
OBSREC_AI_DAILY_LIMIT=20

# Optional but recommended for production rate limits:
# https://upstash.com/


# OBS WebSocket defaults
OBS_WEBSOCKET_HOST=localhost
OBS_WEBSOCKET_PORT=4455
OBS_WEBSOCKET_PASSWORD=
